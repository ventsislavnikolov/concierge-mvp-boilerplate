# ── Validation core ──────────────────────────────────────────────
# Convex (leads storage). `npx convex dev` writes these to .env.local;
# absent env = Convex features offline, landing still renders.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
# Same as VITE_CONVEX_URL but ending in .site (Better Auth proxy target).
VITE_CONVEX_SITE_URL=

# PostHog (analytics). Absent key = no-op.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Resend (welcome email) lives in the CONVEX deployment env, not here:
#   npx convex env set RESEND_API_KEY re_…
#   npx convex env set EMAIL_FROM hello@yourdomain.com   (optional)
# Absent key = welcome email no-ops.

# ── Product add-ons (opt-in; absent env = module no-op) ──────────
# Better Auth lives in the CONVEX deployment env, not here:
#   npx convex env set BETTER_AUTH_SECRET $(openssl rand -base64 32)
#   npx convex env set SITE_URL https://yourdomain.com
#   npx convex env set GOOGLE_CLIENT_ID …        (optional — Google sign-in)
#   npx convex env set GOOGLE_CLIENT_SECRET …    (optional — Google sign-in)
# Google Cloud Console redirect URI: <SITE_URL>/api/auth/callback/google
# Absent Google env = magic link only; /admin + /app stay locked without auth.

# Telegram bot (grammY) — wired in ticket #17
# TELEGRAM_BOT_TOKEN=

# Sentry — wired in ticket #18
# SENTRY_DSN=

# AI SDK — optional
# ANTHROPIC_API_KEY=
