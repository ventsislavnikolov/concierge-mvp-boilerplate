# ── Validation core ──────────────────────────────────────────────
# Convex (leads storage). `npx convex dev` writes these to .env.local;
# absent env = Convex features offline, landing still renders.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# PostHog (analytics). Absent key = no-op.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Resend (welcome email) lives in the CONVEX deployment env, not here:
#   npx convex env set RESEND_API_KEY re_…
#   npx convex env set EMAIL_FROM hello@yourdomain.com   (optional)
# Absent key = welcome email no-ops.

# ── Product add-ons (opt-in; absent env = module no-op) ──────────
# Better Auth — wired in ticket #9
# BETTER_AUTH_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Telegram bot (grammY) — wired in ticket #17
# TELEGRAM_BOT_TOKEN=

# Sentry — wired in ticket #18
# SENTRY_DSN=

# AI SDK — optional
# ANTHROPIC_API_KEY=
